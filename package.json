{
  "name": "api-de-triagem-ci-cd",
  "version": "1.0.0",
  "description": "API de triagem e acompanhamento de atendimentos para experimento de métricas CI/CD.",
  "type": "module",
  "private": false,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:summary": "node scripts/summarize-tests.mjs",
    "pipeline:context": "node scripts/write-pipeline-context.mjs",
    "metrics:collect": "node scripts/collect-metrics.mjs",
    "charts": "node scripts/generate-charts.mjs",
    "experiment:variation": "node scripts/apply-variation.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "fastify": "^5.6.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.14",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
